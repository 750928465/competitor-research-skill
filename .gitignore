# 竞品分析技能项目 .gitignore

# 本地运行时配置（包含真实密钥）
config/runtime.local.yaml

# Claude Code 个人配置
.claude/

# 前端依赖
frontend/node_modules/

# 前端构建产物
frontend/.next/
frontend/out/

# 输出目录（生成的报告）
output/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
/lib/
/lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# macOS
.DS_Store
.AppleDouble
.LSOverride

# 日志
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 环境变量文件
.env
.env.local
.env.*.local
frontend/.env
frontend/.env.local
frontend/.env.*.local

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Session exports
*.txt